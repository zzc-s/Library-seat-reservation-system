# 复制为项目根目录 .env 后填入真实值：cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root-password
DB_USERNAME=library
DB_PASSWORD=change-me-db-password

# JWT（至少 32 字节随机串）
JWT_SECRET=change-me-to-at-least-32-bytes-secret-key

# QQ 邮箱 SMTP
MAIL_USERNAME=your@qq.com
MAIL_PASSWORD=your-qq-mail-app-password
MAIL_FROM=your@qq.com

# 公网访问地址（签到二维码用）
FRONTEND_BASE_URL=http://8.136.47.73
