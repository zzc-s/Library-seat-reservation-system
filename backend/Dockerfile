FROM maven:3.9-eclipse-temurin-17 AS build
WORKDIR /app
COPY pom.xml .
COPY src ./src
RUN mvn package -DskipTests -q

FROM eclipse-temurin:17-jre-jammy
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /app/target/library-seat-backend-0.0.1-SNAPSHOT.jar app.jar
RUN mkdir -p /app/uploads/avatars /app/uploads/book-covers
VOLUME ["/app/uploads"]
EXPOSE 8081
ENTRYPOINT ["java", "-jar", "app.jar", "--spring.config.additional-location=optional:file:/app/config/application-prod.yml"]
